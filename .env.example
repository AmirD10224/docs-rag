# DocsRAG environment configuration.
# Copy to .env and fill in. NEVER commit the populated .env.

# --- Provider keys (required for live mode) ---
ANTHROPIC_API_KEY=sk-ant-...
COHERE_API_KEY=...
JINA_API_KEY=jina_...

# --- Vector store (Qdrant Cloud free tier) ---
QDRANT_URL=https://your-cluster.cloud.qdrant.io:6333
QDRANT_API_KEY=...
QDRANT_COLLECTION=docs_rag

# --- Cache ---
REDIS_URL=redis://localhost:6379/0

# --- App ---
APP_ENV=local
LOG_LEVEL=INFO
ALLOWED_ORIGINS=http://localhost:3000

# --- Models ---
EMBEDDING_MODEL=jina-embeddings-v3
EMBEDDING_DIMENSIONS=1024
RERANK_MODEL=rerank-v3.5
SYNTHESIS_MODEL=claude-sonnet-4-6
JUDGE_MODEL=claude-sonnet-4-6

# --- Behavior ---
# When MOCK_PROVIDERS=true, all external API calls return canned cassette
# responses. Tests use this; deployment overrides to false.
MOCK_PROVIDERS=false
RETRIEVAL_TOP_K_DENSE=50
RETRIEVAL_TOP_K_BM25=50
RERANK_TOP_K=8
QUERY_CACHE_TTL_SECONDS=3600
MAX_PDF_MB=25

# --- Cost tracking (USD per 1M tokens / per 1K queries) ---
PRICE_CLAUDE_INPUT_PER_MTOK=3.0
PRICE_CLAUDE_OUTPUT_PER_MTOK=15.0
PRICE_JINA_PER_MTOK=0.20
PRICE_COHERE_RERANK_PER_1K=2.0
